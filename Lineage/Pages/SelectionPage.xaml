<Page x:Class="Lineage.Pages.SelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lineage.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="800"
      Title="Выбор режима"
      Background="#F5F0E6">

    <Grid>
        <!-- Декоративный элемент -->
        <Border Width="400" Height="400"
                Background="#8B7E6B" Opacity="0.05"
                CornerRadius="200"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>

        <!-- Карточка выбора -->
        <Border Width="650"
                Background="#FDF8F0"
                CornerRadius="20"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B7A48B"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.15"
                                  ShadowDepth="5"
                                  Color="#5C4E3D"/>
            </Border.Effect>

            <StackPanel>
                <!-- Логотип -->
                <Image Source="/Images/icon-tree.png"
                       Width="80" 
                       Height="80" 
                       Margin="0,0,0,15"
                       HorizontalAlignment="Center"/>

                <TextBlock Text="Добро пожаловать!" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#5C4E3D"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Выберите тип проекта" 
                           FontSize="14" 
                           Foreground="#8B7E6B"
                           Margin="0,5,0,30" 
                           HorizontalAlignment="Center"/>

                <!-- Ряд с карточками -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <!-- Карточка "Семейное древо" -->
                    <Border x:Name="FamilyCard" 
                            Width="250" Height="350" 
                            Background="#FDF8F0" 
                            CornerRadius="15" 
                            BorderBrush="#3498DB" 
                            BorderThickness="2"
                            Margin="10" 
                            Cursor="Hand"
                            MouseLeftButtonDown="FamilyCard_Click">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel Margin="15" VerticalAlignment="Center">
                            <TextBlock Text="🏠" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Семейное древо" FontSize="18" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                            <TextBlock Text="Для родословной семьи" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" Foreground="#6B5E4A"/>
                            <TextBlock Text="Истории, воспоминания, биографии" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" Foreground="#8B7E6B"/>
                            <Button Content="Выбрать" Background="#3498DB" Foreground="White" Margin="0,20,0,0" Padding="10,5" BorderThickness="0" Cursor="Hand" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Карточка "Племенная книга" -->
                    <Border x:Name="BreedingCard" 
                            Width="250" Height="350" 
                            Background="#FDF8F0" 
                            CornerRadius="15" 
                            BorderBrush="#27AE60" 
                            BorderThickness="2"
                            Margin="10" 
                            Cursor="Hand"
                            MouseLeftButtonDown="BreedingCard_Click">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel Margin="15" VerticalAlignment="Center">
                            <TextBlock Text="🐄" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Племенная книга" FontSize="18" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                            <TextBlock Text="Для селекции животных" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" Foreground="#6B5E4A"/>
                            <TextBlock Text="Скрещивания, продуктивность, класс" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" Foreground="#8B7E6B"/>
                            <Button Content="Выбрать" 
                                    Background="#27AE60" 
                                    Foreground="White" 
                                    Margin="0,20,0,0" 
                                    Padding="10,5" 
                                    BorderThickness="0" 
                                    Cursor="Hand"
                                    FontSize="12"
                                    FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Кнопка выхода -->
                <Button Content="Выйти" 
                        Click="LogoutButton_Click"
                        Background="Transparent" 
                        Foreground="#E74C3C" 
                        BorderBrush="#E74C3C" 
                        BorderThickness="1.5"
                        Margin="0,30,0,0"
                        Padding="15,8"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        FontWeight="Medium">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#FCE4E4"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#C0392B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>