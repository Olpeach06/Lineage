<Page x:Class="Lineage.Pages.ExhibitionDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Детали выставки"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <Border Width="500"
                Background="#FDF8F0"
                CornerRadius="20"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B7A48B"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.15"
                                  ShadowDepth="5"
                                  Color="#5C4E3D"/>
            </Border.Effect>

            <StackPanel>
                <Image Source="/Images/icon-tree.png" Width="50" Height="50" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="ДЕТАЛИ ВЫСТАВКИ"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#5C4E3D"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtExhibitionName" Text="—" Foreground="#5C4E3D" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Животное:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtAnimalName" Text="—" Foreground="#5C4E3D" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата проведения:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtExhibitionDate" Text="—" Foreground="#5C4E3D" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Место проведения:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtLocation" Text="—" Foreground="#5C4E3D" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Результат:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtResult" Text="—" Foreground="#5C4E3D" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Судья:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtJudgeName" Text="—" Foreground="#5C4E3D" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Оценка:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="txtRating" Text="—" Foreground="#5C4E3D" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Номер сертификата:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" x:Name="txtCertificateNumber" Text="—" Foreground="#5C4E3D" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Примечания:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="8" Grid.Column="1" x:Name="txtNotes" Text="—" Foreground="#5C4E3D" TextWrapping="Wrap" Margin="0,0,0,10"/>
                </Grid>

                <Button Content="ЗАКРЫТЬ"
                        Width="120" Height="35"
                        Background="#8FAA7A" Foreground="White"
                        BorderThickness="0" Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>