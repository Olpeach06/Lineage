<Page x:Class="Lineage.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="1000" d:DesignWidth="1400"
      Title="Отчеты"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Page.Resources>
        <DropShadowEffect x:Key="ShadowEffect"
                          BlurRadius="10"
                          Opacity="0.1"
                          ShadowDepth="2"
                          Color="#5C4E3D"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЕЕ МЕНЮ -->
        <Border Grid.Row="0"
                Background="#FDF8F0"
                BorderBrush="#D6C9B8"
                BorderThickness="0,0,0,1"
                Effect="{StaticResource ShadowEffect}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,40,0">
                    <Image Source="/Images/icon-tree.png" Width="32" Height="32" Margin="0,0,8,0"/>
                    <TextBlock Text="Genealogy" FontSize="20" FontWeight="SemiBold"
                               Foreground="#5C4E3D" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Главная"
                        Click="MainPageButton_Click" Margin="5,0"
                        Background="Transparent" Foreground="#6B5E4A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" Content="Мои проекты"
                        Click="TreesButton_Click" Margin="5,0"
                        Background="Transparent" Foreground="#6B5E4A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="3" Content="Отчеты" IsEnabled="False" Margin="5,0"
                        Background="Transparent" Foreground="#8FAA7A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>

                <Button Grid.Column="4" x:Name="btnUsers" Content="👥 Пользователи"
                        Click="UsersButton_Click" Margin="5,0"
                        Background="Transparent" Foreground="#6B5E4A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="Medium" Cursor="Hand"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#F5F0E6" CornerRadius="20" Padding="10,5,15,5" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="14" Foreground="#8FAA7A" Margin="0,0,8,0" Height="20"/>
                            <TextBlock x:Name="txtUserName" Text="Имя пользователя"
                                       VerticalAlignment="Center" Foreground="#5C4E3D" FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Выйти" Click="LogoutButton_Click"
                            Background="Transparent" BorderBrush="#D6C9B8" BorderThickness="1"
                            Foreground="#8B7E6B" Padding="12,5" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                    <Setter Property="Foreground" Value="#8FAA7A"/>
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#8FAA7A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <ScrollViewer x:Name="mainScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="mainPanel" Margin="30">

                <!-- Динамический заголовок -->
                <TextBlock x:Name="txtPageTitle" 
                           FontSize="24" FontWeight="SemiBold"
                           Foreground="#5C4E3D"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Left"/>

                <!-- Панель фильтров (универсальная) -->
                <Border Background="#FDF8F0" CornerRadius="10" 
        BorderBrush="#D6C9B8" BorderThickness="1" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="🔍 ФИЛЬТРЫ"
                   Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,15"/>

                        <!-- Первая строка фильтров -->
                        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,10" HorizontalAlignment="Stretch">

                            <!-- Проект -->
                            <Border Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Проект" Foreground="#6B5E4A" FontSize="12" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbFilterTree" Height="32" BorderBrush="#B7A48B"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectionChanged="FilterTree_SelectionChanged"/>
                                </StackPanel>
                            </Border>

                            <!-- Вид (для животных) -->
                            <Border x:Name="panelSpecies" Margin="0,0,10,0" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Вид" Foreground="#6B5E4A" FontSize="12" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbFilterSpecies" Height="32" BorderBrush="#B7A48B"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectionChanged="FilterSpecies_SelectionChanged"/>
                                </StackPanel>
                            </Border>

                            <!-- Порода (для животных) -->
                            <Border x:Name="panelBreed" Margin="0,0,10,0" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Порода" Foreground="#6B5E4A" FontSize="12" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbFilterBreed" Height="32" BorderBrush="#B7A48B"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                                </StackPanel>
                            </Border>

                            <!-- Племенной класс (для животных) -->
                            <Border x:Name="panelClass" Margin="0,0,0,0" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Племенной класс" Foreground="#6B5E4A" FontSize="12" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbFilterClass" Height="32" BorderBrush="#B7A48B"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Вторая строка фильтров -->
                        <UniformGrid Columns="3" Rows="1" HorizontalAlignment="Stretch">

                            <!-- Статус (для животных) -->
                            <Border x:Name="panelStatus" Margin="0,0,15,0" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Статус" Foreground="#6B5E4A" FontSize="12" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbFilterStatus" Height="32" BorderBrush="#B7A48B"
                              SelectedIndex="0">
                                        <ComboBoxItem Content="Все животные"/>
                                        <ComboBoxItem Content="Только живые"/>
                                        <ComboBoxItem Content="Только племенные"/>
                                        <ComboBoxItem Content="Только выбывшие"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- Пол (универсальный с динамическими значениями) -->
                            <Border Margin="0,0,15,0">
                                <StackPanel>
                                    <TextBlock Text="Пол" Foreground="#6B5E4A" FontSize="12" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbFilterGender" Height="32" BorderBrush="#B7A48B"
                              SelectedIndex="0">
                                        <!-- Значения будут заполняться в коде -->
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- Кнопки -->
                            <Border HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Применить" Width="100" Height="32"
                            Background="#8FAA7A" Foreground="White" BorderThickness="0"
                            Margin="0,0,10,0" Click="ApplyFilters_Click"/>
                                    <Button Content="Сбросить" Width="100" Height="32"
                            Background="Transparent" BorderBrush="#D6C9B8" Foreground="#6B5E4A"
                            BorderThickness="1" Click="ResetFilters_Click"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- БЛОКИ СТАТИСТИКИ - ДЛЯ ЛЮДЕЙ -->
                <StackPanel x:Name="panelFamilyStats" Visibility="Collapsed">

                    <!-- Общая статистика (люди) -->
                    <Border Background="#FDF8F0" CornerRadius="10" BorderBrush="#D6C9B8"
                            BorderThickness="1" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="📊 ОБЩАЯ СТАТИСТИКА"
                                       Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="0,0,5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="👥" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtTotalPersons" Text="0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Всего персон" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="♂/♀" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtPersonGenderRatio" Text="0/0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Мужчины/Женщины" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="💍" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtMarriages" Text="0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Браков" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="⚰️" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtDeceased" Text="0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Умерших" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="5,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📊" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtGenerations" Text="0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Поколений" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Возрастная статистика -->
                    <Border Background="#FDF8F0" CornerRadius="10" BorderBrush="#D6C9B8"
        BorderThickness="1" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📈 ВОЗРАСТНАЯ СТАТИСТИКА"
                       Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"
                       Margin="0,0,0,15"/>
                                <Button x:Name="btnCalendar" Grid.Column="1" Content="📅 КАЛЕНДАРЬ"
                    Width="110" Height="32" Background="#8FAA7A" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Click="CalendarButton_Click"
                    Visibility="Collapsed"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Средний возраст:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtAvgAgePerson" Text="0 лет" FontSize="20" FontWeight="Bold" Foreground="#5C4E3D" Margin="0,5,0,10"/>

                                    <TextBlock Text="Самый старший:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtOldestPerson" Text="—" Foreground="#5C4E3D" Margin="0,5,0,10"/>

                                    <TextBlock Text="Самый младший:" Foreground="#6B5E4A" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtYoungestPerson" Text="—" Foreground="#5C4E3D" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Распределение по полу:" Foreground="#6B5E4A" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ProgressBar x:Name="progressMen" Height="20" Minimum="0" Maximum="100" 
                             Foreground="#5C4E3D" Background="#F5F0E6" BorderBrush="#D6C9B8"/>
                                    <TextBlock x:Name="txtMenPercent" Text="0% мужчин" Foreground="#6B5E4A" Margin="0,2,0,5"/>
                                    <ProgressBar x:Name="progressWomen" Height="20" Minimum="0" Maximum="100" 
                             Foreground="#8FAA7A" Background="#F5F0E6" BorderBrush="#D6C9B8"/>
                                    <TextBlock x:Name="txtWomenPercent" Text="0% женщин" Foreground="#6B5E4A" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Популярные имена и фамилии -->
                    <Border Background="#FDF8F0" CornerRadius="10" BorderBrush="#D6C9B8"
                            BorderThickness="1" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="📝 ПОПУЛЯРНЫЕ ИМЕНА И ФАМИЛИИ"
                                       Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Мужские имена" FontWeight="SemiBold" Foreground="#5C4E3D" Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="icMaleNames"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="Женские имена" FontWeight="SemiBold" Foreground="#5C4E3D" Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="icFemaleNames"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Фамилии" FontWeight="SemiBold" Foreground="#5C4E3D" Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="icSurnames"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Список персон -->
                    <Border Background="#FDF8F0" CornerRadius="10" BorderBrush="#D6C9B8"
                            BorderThickness="1" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📋 СПИСОК ПЕРСОН"
                                           Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"/>
                                <Button Grid.Column="1" Content="📊 Экспорт в Excel" Width="130" Height="30"
                                        Background="#8FAA7A" Foreground="White" BorderThickness="0"
                                        Cursor="Hand" Click="ExportToExcel_Click"/>
                            </Grid>
                            <ListView x:Name="lvPersons" BorderThickness="0" Background="Transparent"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="400">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                                        <GridViewColumn Header="Фамилия" Width="120" DisplayMemberBinding="{Binding LastName}"/>
                                        <GridViewColumn Header="Имя" Width="100" DisplayMemberBinding="{Binding FirstName}"/>
                                        <GridViewColumn Header="Отчество" Width="100" DisplayMemberBinding="{Binding Patronymic}"/>
                                        <GridViewColumn Header="Дата рождения" Width="100" DisplayMemberBinding="{Binding BirthDate}"/>
                                        <GridViewColumn Header="Дата смерти" Width="100" DisplayMemberBinding="{Binding DeathDate}"/>
                                        <GridViewColumn Header="Пол" Width="60" DisplayMemberBinding="{Binding Gender}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBlock x:Name="txtNoPersons" Text="Нет данных для отображения" 
                                       Foreground="#8B7E6B" HorizontalAlignment="Center" Margin="20" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- БЛОКИ СТАТИСТИКИ - ДЛЯ ЖИВОТНЫХ -->
                <StackPanel x:Name="panelAnimalStats" Visibility="Collapsed">

                    <!-- Общая статистика (животные) -->
                    <Border Background="#FDF8F0" CornerRadius="10" BorderBrush="#D6C9B8"
                            BorderThickness="1" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="📊 ОБЩАЯ СТАТИСТИКА"
                                       Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="0,0,5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🐄" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtTotalAnimals" Text="0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Всего животных" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="♂/♀" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtAnimalGenderRatio" Text="0/0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Самцы/Самки" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="⭐" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtBreedingStock" Text="0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Племенных" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="❤️" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtAliveAnimals" Text="0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Живых" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📅" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtAvgAgeAnimal" Text="0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Ср. возраст (мес)" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="5" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="5,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🏆" FontSize="28" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtEliteCount" Text="0" FontSize="22" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Элита" Foreground="#8B7E6B" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Распределение по племенным классам -->
                    <Border Background="#FDF8F0" CornerRadius="10" BorderBrush="#D6C9B8"
                            BorderThickness="1" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="🏅 РАСПРЕДЕЛЕНИЕ ПО ПЛЕМЕННЫМ КЛАССАМ"
                                       Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,15"/>
                            <ItemsControl x:Name="icClassDistribution">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="140" Background="#F5F0E6" CornerRadius="8" Padding="12" Margin="0,0,10,0">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding ClassName}" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Count}" FontSize="20" FontWeight="Bold" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Percent}" FontSize="11" Foreground="#8B7E6B" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Воспроизводство и Продуктивность -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#FDF8F0" CornerRadius="10" BorderBrush="#D6C9B8"
                                BorderThickness="1" Padding="20">
                            <StackPanel>
                                <TextBlock Text="🤰 ВОСПРОИЗВОДСТВО"
                                           Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"
                                           Margin="0,0,0,15"/>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Всего вязок:" Foreground="#6B5E4A"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtTotalBreedings" Text="0" Foreground="#5C4E3D" FontWeight="SemiBold"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Успешных:" Foreground="#6B5E4A" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtSuccessfulBreedings" Text="0" Foreground="#5C4E3D" Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Процент успеха:" Foreground="#6B5E4A" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtSuccessRate" Text="0%" Foreground="#5C4E3D" Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Всего потомков:" Foreground="#6B5E4A" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtTotalOffspring" Text="0" Foreground="#5C4E3D" Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Выжило:" Foreground="#6B5E4A" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtAliveOffspring" Text="0" Foreground="#5C4E3D" Margin="0,5,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#FDF8F0" CornerRadius="10" BorderBrush="#D6C9B8"
                                BorderThickness="1" Padding="20">
                            <StackPanel>
                                <TextBlock Text="🥛 ПРОДУКТИВНОСТЬ"
                                           Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"
                                           Margin="0,0,0,15"/>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Средний удой:" Foreground="#6B5E4A"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtAvgMilkYield" Text="0 кг" Foreground="#5C4E3D" FontWeight="SemiBold"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Средняя жирность:" Foreground="#6B5E4A" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtAvgFatContent" Text="0%" Foreground="#5C4E3D" Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Средний белок:" Foreground="#6B5E4A" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtAvgProteinContent" Text="0%" Foreground="#5C4E3D" Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Рекордный удой:" Foreground="#6B5E4A" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtMaxMilkYield" Text="0 кг" Foreground="#5C4E3D" Margin="0,5,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Список животных -->
                    <Border Background="#FDF8F0" CornerRadius="10" BorderBrush="#D6C9B8"
                            BorderThickness="1" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📋 СПИСОК ЖИВОТНЫХ"
                                           Foreground="#5C4E3D" FontSize="16" FontWeight="Bold"/>
                                <Button Grid.Column="1" Content="📊 Экспорт в Excel" Width="130" Height="30"
                                        Background="#8FAA7A" Foreground="White" BorderThickness="0"
                                        Cursor="Hand" Click="ExportToExcel_Click"/>
                            </Grid>
                            <ListView x:Name="lvAnimals" BorderThickness="0" Background="Transparent"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="400">
                                <ListView.View>
                                    <GridView x:Name="gridViewAnimals">
                                        <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                                        <GridViewColumn Header="Кличка" Width="120" DisplayMemberBinding="{Binding Nickname}"/>
                                        <GridViewColumn Header="Инв. номер" Width="100" DisplayMemberBinding="{Binding InventoryNumber}"/>
                                        <GridViewColumn Header="Вид" Width="100" DisplayMemberBinding="{Binding SpeciesName}"/>
                                        <GridViewColumn Header="Порода" Width="120" DisplayMemberBinding="{Binding BreedName}"/>
                                        <GridViewColumn Header="Пол" Width="60" DisplayMemberBinding="{Binding GenderName}"/>
                                        <GridViewColumn Header="Дата рождения" Width="100" DisplayMemberBinding="{Binding BirthDateStr}"/>
                                        <GridViewColumn Header="Класс" Width="80" DisplayMemberBinding="{Binding ClassName}"/>
                                        <GridViewColumn Header="Племенной" Width="70" DisplayMemberBinding="{Binding IsBreedingStockStr}"/>
                                        <GridViewColumn Header="Статус" Width="60" DisplayMemberBinding="{Binding Status}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBlock x:Name="txtNoAnimals" Text="Нет данных для отображения" 
                                       Foreground="#8B7E6B" HorizontalAlignment="Center" Margin="20" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>