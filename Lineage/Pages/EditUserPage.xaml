<Page x:Class="Lineage.Pages.EditUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Редактирование пользователя"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <!-- Карточка -->
        <Border Width="500"
                Background="#FDF8F0"
                CornerRadius="20"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B7A48B"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.15"
                                  ShadowDepth="5"
                                  Color="#5C4E3D"/>
            </Border.Effect>

            <StackPanel>
                <Image Source="/Images/icon-tree.png" Width="50" Height="50" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock x:Name="txtTitle"
                           Text="ДОБАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯ"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#5C4E3D"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Логин -->
                <TextBlock Text="Логин *" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtUsername"
                         Padding="8"
                         BorderBrush="#B7A48B"
                         BorderThickness="0,0,0,1"
                         Background="Transparent"
                         Margin="0,0,0,10"
                         MaxLength="50"/>

                <!-- Email -->
                <TextBlock Text="Email" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtEmail"
                         Padding="8"
                         BorderBrush="#B7A48B"
                         BorderThickness="0,0,0,1"
                         Background="Transparent"
                         Margin="0,0,0,10"
                         MaxLength="100"/>

                <!-- Пароль (только для добавления) -->
                <TextBlock x:Name="txtPasswordLabel" Text="Пароль *" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <PasswordBox x:Name="txtPassword"
                             Padding="8"
                             BorderBrush="#B7A48B"
                             BorderThickness="0,0,0,1"
                             Background="Transparent"
                             Margin="0,0,0,10"/>

                <!-- Подтверждение пароля (только для добавления) -->
                <TextBlock x:Name="txtConfirmLabel" Text="Подтверждение пароля *" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <PasswordBox x:Name="txtConfirmPassword"
                             Padding="8"
                             BorderBrush="#B7A48B"
                             BorderThickness="0,0,0,1"
                             Background="Transparent"
                             Margin="0,0,0,15"/>

                <!-- Роль -->
                <TextBlock Text="Роль" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <ComboBox x:Name="cmbRole"
                          Height="35"
                          BorderBrush="#B7A48B"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          Margin="0,0,0,15"/>

                <!-- Активен -->
                <CheckBox x:Name="chkIsActive"
                          Content="Активен"
                          Foreground="#6B5E4A"
                          IsChecked="True"
                          Margin="0,0,0,20"/>

                <!-- Кнопки -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="ОТМЕНА"
                            Width="120" Height="40"
                            Background="Transparent" BorderBrush="#D6C9B8"
                            Foreground="#6B5E4A" BorderThickness="1"
                            Margin="0,0,10,0" HorizontalAlignment="Right"
                            Click="CancelButton_Click"/>
                    <Button Grid.Column="1" x:Name="btnSave"
                            Content="СОХРАНИТЬ"
                            Width="120" Height="40"
                            Background="#8FAA7A" Foreground="White"
                            BorderThickness="0" Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            Click="SaveButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>