<Page x:Class="Lineage.Pages.AddEditBreedingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="800"
      Title="Вязка"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <Border Width="500"
                Background="#FDF8F0"
                CornerRadius="20"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B7A48B"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.15"
                                  ShadowDepth="5"
                                  Color="#5C4E3D"/>
            </Border.Effect>

            <StackPanel>
                <Image Source="/Images/icon-tree.png" Width="50" Height="50" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock x:Name="txtTitle"
                           Text="ДОБАВЛЕНИЕ ВЯЗКИ"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#5C4E3D"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Производитель (самец) -->
                <TextBlock Text="Производитель (самец)" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <ComboBox x:Name="cmbMale" Height="30" BorderBrush="#B7A48B"
                          DisplayMemberPath="Nickname" SelectedValuePath="Id"
                          Margin="0,0,0,10"/>

                <!-- Матка (самка) -->
                <TextBlock Text="Матка (самка)" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <ComboBox x:Name="cmbFemale" Height="30" BorderBrush="#B7A48B"
                          DisplayMemberPath="Nickname" SelectedValuePath="Id"
                          Margin="0,0,0,10"/>

                <!-- Дата вязки -->
                <TextBlock Text="Дата вязки *" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <DatePicker x:Name="dpBreedingDate" Height="35" BorderBrush="#B7A48B" Margin="0,0,0,10"/>

                <!-- Ожидаемая дата родов -->
                <TextBlock Text="Ожидаемая дата родов" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <DatePicker x:Name="dpExpectedBirth" Height="35" BorderBrush="#B7A48B" Margin="0,0,0,10"/>

                <!-- Фактическая дата родов -->
                <TextBlock Text="Фактическая дата родов" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <DatePicker x:Name="dpActualBirth" Height="35" BorderBrush="#B7A48B" Margin="0,0,0,10"/>

                <!-- Количество потомков -->
                <TextBlock Text="Количество родившихся" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtOffspringCount" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" 
                         Background="Transparent" Margin="0,0,0,10"/>

                <!-- Количество выживших -->
                <TextBlock Text="Количество выживших" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtAliveCount" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" 
                         Background="Transparent" Margin="0,0,0,10"/>

                <!-- Успешность -->
                <CheckBox x:Name="chkIsSuccessful" Content="Вязка успешна" Foreground="#6B5E4A" Margin="0,0,0,10"/>

                <!-- Примечания -->
                <TextBlock Text="Примечания" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtNotes" Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                         Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1"
                         Background="Transparent" Margin="0,0,0,20"/>

                <!-- Кнопки -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="ОТМЕНА"
                            Width="120" Height="40"
                            Background="Transparent" BorderBrush="#D6C9B8"
                            Foreground="#6B5E4A" BorderThickness="1"
                            Margin="0,0,10,0" HorizontalAlignment="Right"
                            Click="CancelButton_Click"/>
                    <Button Grid.Column="1" Content="СОХРАНИТЬ"
                            Width="120" Height="40"
                            Background="#8FAA7A" Foreground="White"
                            BorderThickness="0" Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            Click="SaveButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>