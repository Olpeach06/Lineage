<Page x:Class="Lineage.Pages.AddEditExhibitionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="800"
      Title="Выставка"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <Border Width="500"
                Background="#FDF8F0"
                CornerRadius="20"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B7A48B"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.15"
                                  ShadowDepth="5"
                                  Color="#5C4E3D"/>
            </Border.Effect>

            <StackPanel>
                <Image Source="/Images/icon-tree.png" Width="50" Height="50" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock x:Name="txtTitle"
                           Text="ДОБАВЛЕНИЕ ВЫСТАВКИ"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#5C4E3D"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Название выставки -->
                <TextBlock Text="Название выставки *" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtExhibitionName" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" 
                         Background="Transparent" Margin="0,0,0,10"/>

                <!-- Дата проведения -->
                <TextBlock Text="Дата проведения *" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <DatePicker x:Name="dpExhibitionDate" Height="35" BorderBrush="#B7A48B" Margin="0,0,0,10"/>

                <!-- Место проведения -->
                <TextBlock Text="Место проведения" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtLocation" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" 
                         Background="Transparent" Margin="0,0,0,10"/>

                <!-- Результат -->
                <TextBlock Text="Результат" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtResult" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" 
                         Background="Transparent" Margin="0,0,0,10"/>

                <!-- Судья -->
                <TextBlock Text="Судья" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtJudgeName" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" 
                         Background="Transparent" Margin="0,0,0,10"/>

                <!-- Оценка -->
                <TextBlock Text="Оценка (баллы)" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtRating" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" 
                         Background="Transparent" Margin="0,0,0,10"/>

                <!-- Номер сертификата -->
                <TextBlock Text="Номер сертификата" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtCertificateNumber" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" 
                         Background="Transparent" Margin="0,0,0,10"/>

                <!-- Примечания -->
                <TextBlock Text="Примечания" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBox x:Name="txtNotes" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                         Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1"
                         Background="Transparent" Margin="0,0,0,20"/>

                <!-- Кнопки -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="ОТМЕНА"
                            Width="120" Height="40"
                            Background="Transparent" BorderBrush="#D6C9B8"
                            Foreground="#6B5E4A" BorderThickness="1"
                            Margin="0,0,10,0" HorizontalAlignment="Right"
                            Click="CancelButton_Click"/>
                    <Button Grid.Column="1" Content="СОХРАНИТЬ"
                            Width="120" Height="40"
                            Background="#8FAA7A" Foreground="White"
                            BorderThickness="0" Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            Click="SaveButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>