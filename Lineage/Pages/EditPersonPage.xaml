<Page x:Class="Lineage.Pages.EditPersonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Редактирование персоны"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <!-- Декоративный элемент -->
        <Border Width="500" Height="500"
                Background="#8B7E6B" Opacity="0.05"
                CornerRadius="250"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>

        <!-- Карточка редактирования -->
        <Border Width="950"
                Background="#FDF8F0"
                CornerRadius="20"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B7A48B"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.15"
                                  ShadowDepth="5"
                                  Color="#5C4E3D"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Image Source="/Images/icon-tree.png" Width="50" Height="50" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtTitle"
                               Text="ДОБАВЛЕНИЕ ПЕРСОНЫ"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="#5C4E3D"/>
                    <TextBlock Text="Заполните информацию"
                               Foreground="#8B7E6B"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Основной контент в две колонки -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ЛЕВАЯ КОЛОНКА -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">

                        <!-- Основная информация -->
                        <GroupBox Header="Основная информация"
                                  BorderBrush="#B7A48B"
                                  Foreground="#5C4E3D"
                                  Margin="0,0,0,10">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия *" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtLastName"
                                         Padding="3" BorderBrush="#B7A48B" BorderThickness="0,0,0,1"
                                         Background="Transparent" Height="25" Margin="0,0,0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя *" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtFirstName"
                                         Padding="3" BorderBrush="#B7A48B" BorderThickness="0,0,0,1"
                                         Background="Transparent" Height="25" Margin="0,0,0,5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtPatronymic"
                                         Padding="3" BorderBrush="#B7A48B" BorderThickness="0,0,0,1"
                                         Background="Transparent" Height="25" Margin="0,0,0,5"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Девичья" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtMaidenName"
                                         Padding="3" BorderBrush="#B7A48B" BorderThickness="0,0,0,1"
                                         Background="Transparent" Height="25" Margin="0,0,0,5"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Пол *" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbGender" Height="25"
                                          BorderBrush="#B7A48B" SelectedIndex="0">
                                    <ComboBoxItem Content="Мужской"/>
                                    <ComboBoxItem Content="Женский"/>
                                    <ComboBoxItem Content="Не указан"/>
                                </ComboBox>
                            </Grid>
                        </GroupBox>

                        <!-- Даты жизни -->
                        <GroupBox Header="Даты жизни"
                                  BorderBrush="#B7A48B"
                                  Foreground="#5C4E3D"
                                  Margin="0,0,0,10">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Рождения" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <DatePicker Grid.Row="0" Grid.Column="1" x:Name="dpBirthDate"
                                            Height="25" BorderBrush="#B7A48B"
                                            SelectedDateFormat="Short" Margin="0,0,0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Смерти" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <DatePicker Grid.Row="1" Grid.Column="1" x:Name="dpDeathDate"
                                            Height="25" BorderBrush="#B7A48B"
                                            SelectedDateFormat="Short"/>
                            </Grid>
                        </GroupBox>

                        <!-- Места -->
                        <GroupBox Header="Места"
                                  BorderBrush="#B7A48B"
                                  Foreground="#5C4E3D"
                                  Margin="0,0,0,10">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Рождения" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtBirthPlace"
                                         Padding="3" BorderBrush="#B7A48B" BorderThickness="0,0,0,1"
                                         Background="Transparent" Height="25" Margin="0,0,0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Смерти" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtDeathPlace"
                                         Padding="3" BorderBrush="#B7A48B" BorderThickness="0,0,0,1"
                                         Background="Transparent" Height="25"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- ПРАВАЯ КОЛОНКА -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">

                        <!-- Родственные связи -->
                        <GroupBox Header="Родственные связи"
                                  BorderBrush="#B7A48B"
                                  Foreground="#5C4E3D"
                                  Margin="0,0,0,10">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Отец" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbFather"
                                          Height="25" BorderBrush="#B7A48B"
                                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                                          Margin="0,0,3,5"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="🔍" Width="28" Height="25"
                                        Background="Transparent" BorderBrush="#B7A48B" BorderThickness="1"
                                        Click="FindParent_Click" Tag="Father"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Мать" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbMother"
                                          Height="25" BorderBrush="#B7A48B"
                                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                                          Margin="0,0,3,5"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="🔍" Width="28" Height="25"
                                        Background="Transparent" BorderBrush="#B7A48B" BorderThickness="1"
                                        Click="FindParent_Click" Tag="Mother"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Супруг" Foreground="#6B5E4A" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbSpouse"
                                          Height="25" BorderBrush="#B7A48B"
                                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                                          Margin="0,0,3,0"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="🔍" Width="28" Height="25"
                                        Background="Transparent" BorderBrush="#B7A48B" BorderThickness="1"
                                        Click="FindParent_Click" Tag="Spouse"/>
                            </Grid>
                        </GroupBox>

                        <!-- Биография -->
                        <GroupBox Header="Биография"
                                  BorderBrush="#B7A48B"
                                  Foreground="#5C4E3D"
                                  Margin="0,0,0,10">
                            <TextBox x:Name="txtBiography" Height="100"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Padding="5" BorderBrush="#B7A48B"
                                     Background="Transparent" Margin="8" FontSize="12"/>
                        </GroupBox>

                        <!-- Фотография -->
                        <GroupBox Header="Фотография"
                                  BorderBrush="#B7A48B"
                                  Foreground="#5C4E3D"
                                  Margin="0,0,0,10">
                            <StackPanel Margin="8" Orientation="Horizontal">
                                <Border Width="90" Height="90"
                                        BorderBrush="#B7A48B" BorderThickness="1"
                                        CornerRadius="5" Background="#F5F0E6"
                                        Margin="0,0,8,0">
                                    <Grid>
                                        <Image x:Name="imgPreview" Stretch="UniformToFill" Visibility="Collapsed"/>
                                        <TextBlock x:Name="txtNoImage" Text="📷" FontSize="20"
                                                   Foreground="#B7A48B" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Visibility="Visible"/>
                                    </Grid>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <Button Content="Выбрать" Width="90" Height="25"
                                            Background="#8FAA7A" Foreground="White"
                                            BorderThickness="0" Margin="0,0,0,3"
                                            Click="SelectPhoto_Click"/>
                                    <Button x:Name="btnRemovePhoto" Content="Удалить" Width="90" Height="25"
                                            Background="Transparent" BorderBrush="#D6C9B8"
                                            Foreground="#6B5E4A" BorderThickness="1"
                                            Click="RemovePhoto_Click" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </Grid>

                <!-- Кнопки -->
                <StackPanel Grid.Row="2" Margin="0,5,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="* - обязательные поля"
                                   Foreground="#B7A48B" FontSize="10" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="ОТМЕНА" Width="90" Height="32"
                                Background="Transparent" BorderBrush="#D6C9B8"
                                Foreground="#6B5E4A" BorderThickness="1"
                                Margin="0,0,8,0" Click="CancelButton_Click"/>
                        <Button Grid.Column="2" Content="СОХРАНИТЬ" Width="90" Height="32"
                                Background="#8FAA7A" Foreground="White"
                                BorderThickness="0" Click="SaveButton_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>