<Window x:Class="Lineage.Pages.StoryDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        d:DesignHeight="600" d:DesignWidth="800"
        Title="История"
        Background="#F5F0E6"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="600">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0"
                Background="#FDF8F0"
                BorderBrush="#D6C9B8"
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Назад"
                        Click="BackButton_Click"
                        Background="Transparent"
                        BorderBrush="#B7A48B"
                        Foreground="#5C4E3D"
                        Padding="15,8"
                        BorderThickness="1"
                        Cursor="Hand"/>
                <TextBlock x:Name="txtPageTitle"
                           Text="История"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="#5C4E3D"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!-- Карточка истории -->
                <Border Background="#FDF8F0"
                        CornerRadius="15"
                        Padding="25"
                        BorderBrush="#B7A48B"
                        BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>

                        <!-- Заголовок -->
                        <TextBlock x:Name="txtTitle"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="#5C4E3D"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <!-- Информация о персоне -->
                        <TextBlock x:Name="txtPersonInfo"
                                   Foreground="#8FAA7A"
                                   FontSize="14"
                                   Margin="0,0,0,15"/>

                        <!-- Дата события -->
                        <Border Background="#F5F0E6"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,15">
                            <WrapPanel>
                                <TextBlock Text="📅 " Foreground="#8FAA7A"/>
                                <TextBlock x:Name="txtEventDate"
                                           Text="Дата события:"
                                           Foreground="#6B5E4A"/>
                            </WrapPanel>
                        </Border>

                        <!-- Содержание истории -->
                        <TextBlock Text="📖 Содержание"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#5C4E3D"
                                   Margin="0,0,0,10"/>

                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="txtContent"
                                       TextWrapping="Wrap"
                                       Foreground="#6B5E4A"
                                       LineHeight="25"/>
                        </ScrollViewer>

                        <!-- Медиафайлы к истории -->
                        <TextBlock Text="🖼️ Прикрепленные файлы"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#5C4E3D"
                                   Margin="0,20,0,10"/>

                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icMedia" Margin="5">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="100" Height="100"
                                                Margin="5"
                                                BorderBrush="#B7A48B"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Background="#F5F0E6"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="Media_Click">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Icon}"
                                                           FontSize="30"
                                                           Foreground="#8FAA7A"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,10,0,5"/>
                                                <TextBlock Text="{Binding FileName}"
                                                           Foreground="#6B5E4A"
                                                           FontSize="10"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="40"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>