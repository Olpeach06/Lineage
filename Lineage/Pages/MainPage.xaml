<Page x:Class="Lineage.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Главная страница"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Page.Resources>
        <DropShadowEffect x:Key="ShadowEffect"
                          BlurRadius="10"
                          Opacity="0.1"
                          ShadowDepth="2"
                          Color="#5C4E3D"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЕЕ МЕНЮ -->
        <Border Grid.Row="0"
                Background="#FDF8F0"
                BorderBrush="#D6C9B8"
                BorderThickness="0,0,0,1"
                Effect="{StaticResource ShadowEffect}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,40,0">
                    <Image Source="/Images/icon-tree.png" Width="32" Height="32" Margin="0,0,8,0"/>
                    <TextBlock Text="Genealogy" FontSize="20" FontWeight="SemiBold"
                               Foreground="#5C4E3D" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Навигация -->
                <Button Grid.Column="1" Content="Главная" IsEnabled="False" Margin="5,0"
                        Background="Transparent" Foreground="#8FAA7A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>

                <Button Grid.Column="2" Content="Мои проекты"
                        Click="MyTreesButton_Click" Margin="5,0"
                        Background="Transparent" Foreground="#6B5E4A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="3" Content="Отчеты"
                        Click="ReportsButton_Click" Margin="5,0"
                        Background="Transparent" Foreground="#6B5E4A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="4" x:Name="btnUsers" Content="👥 Пользователи"
                        Click="UsersButton_Click" Margin="5,0"
                        Background="Transparent" Foreground="#6B5E4A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="Medium" Cursor="Hand"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- Профиль и выход -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#F5F0E6" CornerRadius="20" Padding="10,5,15,5" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="14" Foreground="#8FAA7A" Margin="0,0,8,0" Height="20"/>
                            <TextBlock x:Name="txtUserName" Text="Имя пользователя"
                                       VerticalAlignment="Center" Foreground="#5C4E3D" FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                    <Button Grid.Column="5" Content="🔄 Сменить режим"
                            Click="SwitchModeButton_Click"
                            Background="Transparent" 
                            BorderBrush="#D6C9B8" 
                            BorderThickness="1"
                            Foreground="#6B5E4A"
                            Padding="12,8"
                            Margin="10,0"
                            Cursor="Hand"/>
                    <Button Content="Выйти" Click="LogoutButton_Click"
                            Background="Transparent" BorderBrush="#D6C9B8" BorderThickness="1"
                            Foreground="#8B7E6B" Padding="12,5" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                    <Setter Property="Foreground" Value="#8FAA7A"/>
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#8FAA7A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ПАНЕЛЬ ИНСТРУМЕНТОВ -->
        <Border Grid.Row="1"
                Background="#FDF8F0"
                BorderBrush="#D6C9B8"
                BorderThickness="0,0,0,1"
                Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <Border Grid.Column="0" BorderBrush="#D6C9B8" BorderThickness="1" CornerRadius="8" Height="35" Background="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtSearch" Text="Поиск..." Foreground="#8B7E6B"
                                 Background="Transparent" BorderThickness="0" Padding="10,7"
                                 GotFocus="txtSearch_GotFocus" LostFocus="txtSearch_LostFocus"
                                 TextChanged="txtSearch_TextChanged"/>
                        <Button Grid.Column="1" x:Name="btnClearSearch" Content="✕"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Width="30" Visibility="Collapsed" Click="ClearSearch_Click"
                                Foreground="#8B7E6B" FontSize="14" FontWeight="Bold"/>
                        <Button Grid.Column="2" x:Name="btnSearch" Content="🔍"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Фильтр (универсальный) -->
                <ComboBox Grid.Column="1" x:Name="cmbFilter" Margin="10,0,0,0" Height="35"
                          Background="White" BorderBrush="#D6C9B8" SelectedIndex="0"
                          SelectionChanged="Filter_Changed"/>

                <!-- Кнопки действий -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0">
                    <Button x:Name="btnAdd" Content="➕" Width="35" Height="35"
                            ToolTip="Добавить" Background="Transparent" BorderBrush="#D6C9B8"
                            BorderThickness="1" Margin="2" Cursor="Hand" Click="AddButton_Click"/>
                    <Button x:Name="btnEdit" Content="✎" Width="35" Height="35"
                            ToolTip="Редактировать" Background="Transparent" BorderBrush="#D6C9B8"
                            BorderThickness="1" Margin="2" Cursor="Hand" Click="EditButton_Click"/>
                    <Button x:Name="btnDelete" Content="🗑" Width="35" Height="35"
                            ToolTip="Удалить" Background="Transparent" BorderBrush="#D6C9B8"
                            BorderThickness="1" Margin="2" Cursor="Hand" Click="DeleteButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОБЛАСТЬ ДЕРЕВА -->
        <Border Grid.Row="2" Background="#FDF8F0" Margin="10" CornerRadius="8"
                BorderBrush="#D6C9B8" BorderThickness="1">
            <ScrollViewer x:Name="mainScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="treeCanvas" Width="2000" Height="1500" Background="#FDF8F0"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"/>
            </ScrollViewer>
        </Border>

        <!-- БОКОВАЯ ПАНЕЛЬ (информация о выбранной персоне/животном) -->
        <Border Grid.Row="3" Background="#FDF8F0" Margin="10" CornerRadius="8"
                BorderBrush="#D6C9B8" BorderThickness="1" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <!-- Фото -->
                <Border Grid.Column="0" Width="100" Height="100" BorderBrush="#D6C9B8"
                        BorderThickness="1" CornerRadius="5" Background="#F5F0E6"
                        HorizontalAlignment="Left">
                    <Grid>
                        <Image x:Name="imgProfile" Stretch="UniformToFill" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtNoPhoto" Text="📷" FontSize="40"
                                   Foreground="#B7A48B" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Visibility="Visible" Height="65"/>
                    </Grid>
                </Border>

                <!-- Информация -->
                <StackPanel Grid.Column="1" Margin="15,0">
                    <TextBlock x:Name="txtPersonName" Text="Выберите элемент"
                               FontSize="18" FontWeight="SemiBold" Foreground="#5C4E3D"/>
                    <WrapPanel Margin="0,5">
                        <TextBlock Text="📅 " Foreground="#8FAA7A"/>
                        <TextBlock x:Name="txtBirthDate" Text="--" Foreground="#6B5E4A"/>
                        <TextBlock Text=" - " Foreground="#6B5E4A"/>
                        <TextBlock x:Name="txtDeathDate" Text="--" Foreground="#6B5E4A"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock x:Name="txtGenderSymbol" Text="👤" Foreground="#8FAA7A"/>
                        <TextBlock x:Name="txtGender" Text="Не указан" Foreground="#6B5E4A" Margin="2,0,0,0"/>
                    </WrapPanel>
                    <TextBlock x:Name="txtExtraInfo1" Text="" Margin="0,5" Foreground="#6B5E4A"/>
                    <TextBlock x:Name="txtExtraInfo2" Text=""/>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <Button x:Name="btnDetails" Content="ПОДРОБНЕЕ"
                            Width="100" Height="30" Background="#8FAA7A" Foreground="White"
                            BorderThickness="0" Margin="0,0,0,5" Click="DetailsButton_Click"/>
                    <Button x:Name="btnSideEdit" Content="✎ Редактировать"
                            Width="100" Height="30" Background="Transparent"
                            BorderBrush="#D6C9B8" Foreground="#6B5E4A"
                            BorderThickness="1" Margin="0,0,0,5" Click="EditButton_Click"/>
                    <Button x:Name="btnSideStory" Content="📖 История"
                            Width="100" Height="30" Background="Transparent"
                            BorderBrush="#D6C9B8" Foreground="#6B5E4A"
                            BorderThickness="1" Click="AddStoryButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>