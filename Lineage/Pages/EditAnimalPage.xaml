<Page x:Class="Lineage.Pages.EditAnimalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1100"
      Title="Редактирование животного"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <Border Width="1000"
                Background="#FDF8F0"
                CornerRadius="20"
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B7A48B"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.15"
                                  ShadowDepth="5"
                                  Color="#5C4E3D"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Image Source="/Images/icon-tree.png" Width="45" Height="45" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtTitle"
                               Text="ДОБАВЛЕНИЕ ЖИВОТНОГО"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="#5C4E3D"/>
                </StackPanel>

                <!-- Основные поля в 3 колонки -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="550">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- КОЛОНКА 1 -->
                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="Кличка *" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtNickname" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>

                                <TextBlock Text="Инвентарный номер" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtInventoryNumber" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>

                                <TextBlock Text="Вид *" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <ComboBox x:Name="cmbSpecies" Height="35" BorderBrush="#B7A48B" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="Species_SelectionChanged" Margin="0,0,0,10"/>

                                <TextBlock Text="Порода" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <ComboBox x:Name="cmbBreed" Height="35" BorderBrush="#B7A48B" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10"/>

                                <TextBlock Text="Масть/Окрас" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <ComboBox x:Name="cmbColor" Height="35" BorderBrush="#B7A48B" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10"/>

                                <TextBlock Text="Пол *" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <ComboBox x:Name="cmbGender" Height="35" BorderBrush="#B7A48B" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10"/>

                                <CheckBox x:Name="chkIsCastrated" Content="Кастрирован" Foreground="#6B5E4A" Margin="0,0,0,10"/>
                            </StackPanel>

                            <!-- КОЛОНКА 2 -->
                            <StackPanel Grid.Column="1" Margin="15,0">
                                <TextBlock Text="Дата рождения" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <DatePicker x:Name="dpBirthDate" Height="35" BorderBrush="#B7A48B" Margin="0,0,0,10"/>

                                <TextBlock Text="Место рождения" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtBirthPlace" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>

                                <TextBlock Text="Дата смерти" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <DatePicker x:Name="dpDeathDate" Height="35" BorderBrush="#B7A48B" Margin="0,0,0,10"/>

                                <TextBlock Text="Место смерти" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtDeathPlace" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>

                                <TextBlock Text="Причина смерти" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtDeathReason" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>

                                <TextBlock Text="Номер чипа/тату" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtChipNumber" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>
                            </StackPanel>

                            <!-- КОЛОНКА 3 -->
                            <StackPanel Grid.Column="2" Margin="15,0,0,0">
                                <TextBlock Text="Племенной класс" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <ComboBox x:Name="cmbPedigreeClass" Height="35" BorderBrush="#B7A48B" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10"/>

                                <TextBlock Text="Племенная ценность" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtBreedingValue" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>

                                <CheckBox x:Name="chkIsBreedingStock" Content="Племенное животное" Foreground="#6B5E4A" IsChecked="True" Margin="0,0,0,10"/>

                                <TextBlock Text="Высота в холке (см)" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtHeight" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>

                                <TextBlock Text="Обхват груди (см)" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtChestGirth" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>

                                <TextBlock Text="Вес (кг)" Foreground="#6B5E4A" FontSize="13" FontWeight="Medium" Margin="0,5,0,3"/>
                                <TextBox x:Name="txtWeight" Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>
                            </StackPanel>
                        </Grid>

                        <!-- Родословная (родители) -->
                        <GroupBox Header="Родословная (родители)" BorderBrush="#B7A48B" Foreground="#5C4E3D" Margin="0,15,0,10">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Отец" Foreground="#6B5E4A" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbFather" Height="35" BorderBrush="#B7A48B" DisplayMemberPath="Nickname" SelectedValuePath="Id" Margin="0,0,0,5"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Мать" Foreground="#6B5E4A" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbMother" Height="35" BorderBrush="#B7A48B" DisplayMemberPath="Nickname" SelectedValuePath="Id" Margin="0,0,0,5"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- Продуктивность (JSON) -->
                        <GroupBox Header="Продуктивность (JSON-формат)" BorderBrush="#B7A48B" Foreground="#5C4E3D" Margin="0,5,0,10">
                            <TextBox x:Name="txtProductivityData" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                     Padding="8" BorderBrush="#B7A48B" Background="Transparent" Margin="10"
                                     ToolTip='Пример: {"milkYield":9850, "fatContent":3.8, "proteinContent":3.2}'/>
                        </GroupBox>

                        <!-- Описание -->
                        <GroupBox Header="Описание / Примечания" BorderBrush="#B7A48B" Foreground="#5C4E3D" Margin="0,5,0,10">
                            <TextBox x:Name="txtDescription" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                     Padding="8" BorderBrush="#B7A48B" Background="Transparent" Margin="10"/>
                        </GroupBox>

                        <!-- Фото -->
                        <GroupBox Header="Фотография" BorderBrush="#B7A48B" Foreground="#5C4E3D" Margin="0,5,0,10">
                            <StackPanel Orientation="Horizontal" Margin="10">
                                <Border Width="80" Height="80" BorderBrush="#B7A48B" BorderThickness="1" CornerRadius="5" Background="#F5F0E6" Margin="0,0,10,0">
                                    <Grid>
                                        <Image x:Name="imgPreview" Stretch="UniformToFill" Visibility="Collapsed"/>
                                        <TextBlock x:Name="txtNoImage" Text="📷" FontSize="25" Foreground="#B7A48B" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
                                    </Grid>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <Button Content="Выбрать фото" Width="100" Height="28" Background="#8FAA7A" Foreground="White" BorderThickness="0" Margin="0,0,0,5" Click="SelectPhoto_Click"/>
                                    <Button x:Name="btnRemovePhoto" Content="Удалить" Width="100" Height="28" Background="Transparent" BorderBrush="#D6C9B8" Foreground="#6B5E4A" BorderThickness="1" Click="RemovePhoto_Click" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Кнопки -->
                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="* - обязательные поля" Foreground="#B7A48B" FontSize="10" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="ОТМЕНА" Width="100" Height="35" Background="Transparent" BorderBrush="#D6C9B8" Foreground="#6B5E4A" BorderThickness="1" Margin="0,0,10,0" Click="CancelButton_Click"/>
                        <Button Grid.Column="2" x:Name="btnSave" Content="СОХРАНИТЬ" Width="100" Height="35" Background="#8FAA7A" Foreground="White" BorderThickness="0" Click="SaveButton_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>