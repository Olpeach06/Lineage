<Page x:Class="Lineage.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lineage.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="Авторизация"
      Background="#F5F0E6">

    <Grid>
        <!-- Карточка входа -->
        <Border Width="450"
                Background="#FDF8F0"
                CornerRadius="20"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B7A48B"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.15"
                                  ShadowDepth="5"
                                  Color="#5C4E3D"/>
            </Border.Effect>

            <StackPanel>
                <Image Source="/Images/icon-tree.png" Width="80" Height="80" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <!-- Заголовок -->
                <TextBlock Text="Генеалогическая система"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#5C4E3D"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Войдите в свой аккаунт"
                           Foreground="#8B7E6B"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <!-- Поле Логин -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Логин или Email"
                               Foreground="#6B5E4A"
                               FontSize="12"
                               FontWeight="Medium"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtLogin"
                             FontSize="14"
                             Padding="12"
                             BorderBrush="#B7A48B"
                             BorderThickness="0,0,0,1"
                             Background="Transparent"
                             Foreground="#3A3229"
                             KeyDown="TextBox_KeyDown"/>
                </StackPanel>

                <!-- Поле Пароль -->
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Пароль"
                               Foreground="#6B5E4A"
                               FontSize="12"
                               FontWeight="Medium"
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassword"
                                 FontSize="14"
                                 Padding="12"
                                 BorderBrush="#B7A48B"
                                 BorderThickness="0,0,0,1"
                                 Background="Transparent"
                                 Foreground="#3A3229"
                                 KeyDown="PasswordBox_KeyDown"/>
                </StackPanel>

                <!-- Кнопка Войти -->
                <Button x:Name="btnLogin"
                        Content="ВОЙТИ"
                        Click="LoginButton_Click"
                        Background="#8FAA7A"
                        Foreground="White"
                        FontSize="14" FontWeight="Bold"
                        Height="48"
                        BorderThickness="0"
                        Margin="0,0,0,15"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#A2BD8C"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#7A9270"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Разделитель -->
                <Grid Margin="0,10,0,10">
                    <Border Height="1" Background="#D6C9B8"/>
                    <TextBlock Text="или"
                               Background="#FDF8F0"
                               Foreground="#8B7E6B"
                               Padding="15,0,15,0"
                               HorizontalAlignment="Center"/>
                </Grid>

                <!-- Кнопка Гость -->
                <Button Content="ПРОСМОТРЕТЬ ПУБЛИЧНОЕ ДРЕВО"
                        Click="GuestLoginButton_Click"
                        Background="Transparent"
                        Foreground="#6B5E4A"
                        FontSize="13" FontWeight="Medium"
                        Height="45"
                        BorderThickness="1.5"
                        BorderBrush="#D6C9B8"
                        Margin="0,0,0,20"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="guestBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="guestBorder" Property="Background" Value="#F0E9DE"/>
                                                <Setter TargetName="guestBorder" Property="BorderBrush" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Ссылка на регистрацию -->
                <TextBlock HorizontalAlignment="Center"
                           Foreground="#6B5E4A"
                           FontSize="13">
                    <Hyperlink Click="RegisterHyperlink_Click"
                               Foreground="#8FAA7A"
                               TextDecorations="None"
                               FontWeight="Medium">
                        Создать аккаунт
                    </Hyperlink>
                    <Run Text="— это бесплатно"/>
                </TextBlock>

                <!-- Информация -->
                <TextBlock Text="Первый пользователь становится администратором"
                           Foreground="#B7A48B"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
