<Page x:Class="Lineage.Pages.AddEditHealthEventPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="650" d:DesignWidth="550"
      Title="Ветеринарное событие"
      Background="#F5F0E6">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Width="500"
                    Background="#FDF8F0"
                    CornerRadius="20"
                    Padding="30"
                    HorizontalAlignment="Center"
                    Margin="20"
                    BorderBrush="#B7A48B"
                    BorderThickness="1">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      Opacity="0.15"
                                      ShadowDepth="5"
                                      Color="#5C4E3D"/>
                </Border.Effect>

                <StackPanel>
                    <Image Source="/Images/icon-tree.png" Width="50" Height="50" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock x:Name="txtTitle"
                               Text="ДОБАВЛЕНИЕ ВЕТЕРИНАРНОГО СОБЫТИЯ"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#5C4E3D"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Дата события и Тип события (в одной строке) -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Дата события *" Foreground="#6B5E4A" Margin="0,0,0,2"/>
                            <DatePicker x:Name="dpEventDate" Height="35" BorderBrush="#B7A48B"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Тип события *" Foreground="#6B5E4A" Margin="0,0,0,2"/>
                            <ComboBox x:Name="cmbEventType" Height="35" BorderBrush="#B7A48B"
                                      DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>
                    </Grid>

                    <!-- Препарат и Дозировка (в одной строке) -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Препарат" Foreground="#6B5E4A" Margin="0,0,0,2"/>
                            <TextBox x:Name="txtMedicineName" Padding="8" BorderBrush="#B7A48B" 
                                     BorderThickness="0,0,0,1" Background="Transparent"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Дозировка" Foreground="#6B5E4A" Margin="0,0,0,2"/>
                            <TextBox x:Name="txtDosage" Padding="8" BorderBrush="#B7A48B" 
                                     BorderThickness="0,0,0,1" Background="Transparent"/>
                        </StackPanel>
                    </Grid>

                    <!-- Ветеринар и Следующая обработка (в одной строке) -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ветеринар" Foreground="#6B5E4A" Margin="0,0,0,2"/>
                            <TextBox x:Name="txtVetName" Padding="8" BorderBrush="#B7A48B" 
                                     BorderThickness="0,0,0,1" Background="Transparent"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Следующая обработка" Foreground="#6B5E4A" Margin="0,0,0,2"/>
                            <DatePicker x:Name="dpNextDueDate" Height="35" BorderBrush="#B7A48B"/>
                        </StackPanel>
                    </Grid>

                    <!-- Стоимость -->
                    <TextBlock Text="Стоимость (руб)" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                    <TextBox x:Name="txtCost" Padding="8" BorderBrush="#B7A48B" 
                             BorderThickness="0,0,0,1" Background="Transparent" Margin="0,0,0,10"/>

                    <!-- Примечания -->
                    <TextBlock Text="Примечания" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                    <TextBox x:Name="txtNotes" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                             Padding="8" BorderBrush="#B7A48B" BorderThickness="0,0,0,1"
                             Background="Transparent" Margin="0,0,0,20"/>

                    <!-- Кнопки -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="ОТМЕНА"
                                Width="120" Height="40"
                                Background="Transparent" BorderBrush="#D6C9B8"
                                Foreground="#6B5E4A" BorderThickness="1"
                                Margin="0,0,10,0" HorizontalAlignment="Right"
                                Click="CancelButton_Click"/>
                        <Button Grid.Column="1" Content="СОХРАНИТЬ"
                                Width="120" Height="40"
                                Background="#8FAA7A" Foreground="White"
                                BorderThickness="0" Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                Click="SaveButton_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>