<Page x:Class="Lineage.Pages.TreesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Мои проекты"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Page.Resources>
        <DropShadowEffect x:Key="ShadowEffect"
                          BlurRadius="10"
                          Opacity="0.1"
                          ShadowDepth="2"
                          Color="#5C4E3D"/>

        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЕЕ МЕНЮ -->
        <Border Grid.Row="0"
                Background="#FDF8F0"
                BorderBrush="#D6C9B8"
                BorderThickness="0,0,0,1"
                Effect="{StaticResource ShadowEffect}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,40,0">
                    <Image Source="/Images/icon-tree.png" Width="32" Height="32" Margin="0,0,8,0"/>
                    <TextBlock Text="Genealogy" FontSize="20" FontWeight="SemiBold"
                               Foreground="#5C4E3D" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Навигация -->
                <Button Grid.Column="1" Content="Главная"
                        Click="MainPageButton_Click" Margin="5,0"
                        Background="Transparent" Foreground="#6B5E4A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" Content="Мои проекты" IsEnabled="False" Margin="5,0"
                        Background="Transparent" Foreground="#8FAA7A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>

                <Button Grid.Column="3" Content="Отчеты"
                        Click="ReportsButton_Click" Margin="5,0"
                        Background="Transparent" Foreground="#6B5E4A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="4" x:Name="btnUsers" Content="👥 Пользователи"
                        Click="UsersButton_Click" Margin="5,0"
                        Background="Transparent" Foreground="#6B5E4A"
                        BorderThickness="0" Padding="15,8"
                        FontSize="14" FontWeight="Medium" Cursor="Hand"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Профиль и выход -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#F5F0E6" CornerRadius="20" Padding="10,5,15,5" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="14" Foreground="#8FAA7A" Margin="0,0,8,0" Height="20"/>
                            <TextBlock x:Name="txtUserName" Text="Имя пользователя"
                                       VerticalAlignment="Center" Foreground="#5C4E3D" FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Выйти" Click="LogoutButton_Click"
                            Background="Transparent" BorderBrush="#D6C9B8" BorderThickness="1"
                            Foreground="#8B7E6B" Padding="12,5" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                    <Setter Property="Foreground" Value="#8FAA7A"/>
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#8FAA7A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">

                <!-- Заголовок и кнопка создания -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="МОИ ПРОЕКТЫ"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#5C4E3D"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="btnCreateTree"
                            Content="➕ СОЗДАТЬ"
                            Width="120" Height="40"
                            Background="#8FAA7A"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CreateTreeButton_Click"/>
                </Grid>

                <!-- ТЕКУЩИЙ ПРОЕКТ -->
                <Border x:Name="borderCurrentTree"
                        Background="#FDF8F0"
                        CornerRadius="10"
                        BorderBrush="#8FAA7A"
                        BorderThickness="2"
                        Padding="20"
                        Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="● ТЕКУЩИЙ ПРОЕКТ"
                                   Foreground="#8FAA7A"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <Border x:Name="currentTreeCard"
                                Background="#F5F0E6"
                                CornerRadius="8"
                                Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="🌳"
                                           FontSize="32"
                                           Foreground="#8FAA7A"
                                           Margin="0,0,15,0"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="txtCurrentTreeName"
                                               Text="Название проекта"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="#5C4E3D"/>
                                    <TextBlock x:Name="txtCurrentTreeDesc"
                                               Text="Описание проекта"
                                               Foreground="#8B7E6B"
                                               Margin="0,2,0,5"
                                               TextWrapping="Wrap"/>
                                    <WrapPanel>
                                        <TextBlock x:Name="txtCurrentTreeStats"
                                                   Text="👥 0 персон | 📖 0 историй | 📷 0 фото"
                                                   Foreground="#6B5E4A"
                                                   FontSize="12"/>
                                    </WrapPanel>
                                    <TextBlock x:Name="txtCurrentTreeDate"
                                               Text="Создано: "
                                               Foreground="#B7A48B"
                                               FontSize="11"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="ВЫБРАНО"
                                            Width="80" Height="30"
                                            Background="#8FAA7A"
                                            Foreground="White"
                                            BorderThickness="0"
                                            IsEnabled="False"
                                            Margin="0,0,5,0"/>
                                    <Button x:Name="btnEditCurrent"
                                            Content="✎"
                                            Width="30" Height="30"
                                            Background="Transparent"
                                            BorderBrush="#D6C9B8"
                                            Foreground="#6B5E4A"
                                            BorderThickness="1"
                                            Margin="0,0,5,0"
                                            Click="EditTreeButton_Click"/>
                                    <Button x:Name="btnDeleteCurrent"
                                            Content="🗑"
                                            Width="30" Height="30"
                                            Background="Transparent"
                                            BorderBrush="#D6C9B8"
                                            Foreground="#6B5E4A"
                                            BorderThickness="1"
                                            Click="DeleteTreeButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ДРУГИЕ ПРОЕКТЫ -->
                <Border Background="#FDF8F0"
                        CornerRadius="10"
                        BorderBrush="#D6C9B8"
                        BorderThickness="1"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="● ДРУГИЕ ПРОЕКТЫ"
                                   Foreground="#8B7E6B"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ListView x:Name="lvTrees"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  MaxHeight="500"
                                  HorizontalAlignment="Stretch">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F5F0E6"
                                            CornerRadius="8"
                                            Padding="15"
                                            Margin="0,0,0,10"
                                            HorizontalAlignment="Stretch">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="🌳"
                                                       FontSize="32"
                                                       Foreground="#8FAA7A"
                                                       Margin="0,0,15,0"
                                                       VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="1"
                                                        HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="18" FontWeight="Bold"
                                                           Foreground="#5C4E3D"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="#8B7E6B"
                                                           Margin="0,2,0,5"
                                                           TextWrapping="Wrap"/>
                                                <WrapPanel>
                                                    <TextBlock Text="{Binding Stats}"
                                                               Foreground="#6B5E4A"
                                                               FontSize="12"/>
                                                </WrapPanel>
                                                <TextBlock Text="{Binding CreatedDate}"
                                                           Foreground="#B7A48B"
                                                           FontSize="11"
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <Button Content="ВЫБРАТЬ"
                                                        Width="80" Height="30"
                                                        Background="#8FAA7A"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Margin="0,0,5,0"
                                                        Tag="{Binding Id}"
                                                        Click="SelectTreeButton_Click"/>
                                                <Button Content="✎"
                                                        Width="30" Height="30"
                                                        Background="Transparent"
                                                        BorderBrush="#D6C9B8"
                                                        Foreground="#6B5E4A"
                                                        BorderThickness="1"
                                                        Margin="0,0,5,0"
                                                        Tag="{Binding Id}"
                                                        Click="EditTreeButton_Click"/>
                                                <Button Content="🗑"
                                                        Width="30" Height="30"
                                                        Background="Transparent"
                                                        BorderBrush="#D6C9B8"
                                                        Foreground="#6B5E4A"
                                                        BorderThickness="1"
                                                        Tag="{Binding Id}"
                                                        Click="DeleteTreeButton_Click"
                                                        Visibility="{Binding ShowDeleteButton}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Сообщение, если нет проектов -->
                        <Border x:Name="borderNoTrees"
                                Background="#F5F0E6"
                                CornerRadius="8"
                                Padding="30"
                                Margin="10"
                                Visibility="Collapsed"
                                HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🌳"
                                           FontSize="48"
                                           Foreground="#D6C9B8"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtNoTrees"
                                           Text="У вас пока нет проектов. Создайте новый!"
                                           Foreground="#B7A48B"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>