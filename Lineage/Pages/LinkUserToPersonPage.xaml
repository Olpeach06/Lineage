<Page x:Class="Lineage.Pages.LinkUserToPersonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Привязка пользователя к персоне"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <Border Width="500"
                Background="#FDF8F0"
                CornerRadius="20"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B7A48B"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.15"
                                  ShadowDepth="5"
                                  Color="#5C4E3D"/>
            </Border.Effect>

            <StackPanel>
                <Image Source="/Images/icon-tree.png" Width="50" Height="50" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="ПРИВЯЗКА ПОЛЬЗОВАТЕЛЯ"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#5C4E3D"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Пользователь:" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <TextBlock x:Name="txtUserName"
                           Text="---"
                           Foreground="#5C4E3D"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Выберите персону:" Foreground="#6B5E4A" Margin="0,5,0,2"/>
                <ComboBox x:Name="cmbPerson"
                          Height="35"
                          BorderBrush="#B7A48B"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          Margin="0,0,0,15"/>

                <Button x:Name="btnClear"
                        Content="Очистить привязку"
                        Width="150" Height="35"
                        Background="Transparent"
                        BorderBrush="#D6C9B8"
                        Foreground="#6B5E4A"
                        BorderThickness="1"
                        Margin="0,0,0,15"
                        Click="ClearLinkButton_Click"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="ОТМЕНА"
                            Width="120" Height="40"
                            Background="Transparent" BorderBrush="#D6C9B8"
                            Foreground="#6B5E4A" BorderThickness="1"
                            Margin="0,0,10,0" HorizontalAlignment="Right"
                            Click="CancelButton_Click"/>
                    <Button Grid.Column="1" Content="СОХРАНИТЬ"
                            Width="120" Height="40"
                            Background="#8FAA7A" Foreground="White"
                            BorderThickness="0" Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            Click="SaveButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>